NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/nssec_dashboard

# JWT
JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Resend
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=NSSEC <noreply@nssec.gov.ng>
EMAIL_REPLY_TO=admin@nssec.gov.ng

# Super Admin seed (first run)
SEED_SUPER_ADMIN_EMAIL=admin@nssec.gov.ng
SEED_SUPER_ADMIN_PASSWORD=Change_Me_Immediately!
